      "realization": "corpus-body",
      "canonical": {
        "category": "Epistemic discipline",
        "home": "quality/rules_library.md",
        "body": "Mark uncertainty at the point you make a claim, not only in QA review. When an agent states something it has not verified, it says so plainly (\"I believe X but have not confirmed it\") rather than presenting a guess as fact. Confident-sounding claims that turn out to be guesses are a failure mode; an honest \"I'm not sure\" is not."
      },
      "target_hooks": [
        {
          "target": "CLAUDE.md",
          "hook_type": "cross_ref",
          "text": "Governed by operating principle OP-08 — see quality/rules_library.md."
