      "emission_posture": "install-verbatim",
      "public_source_label": "inherited operating principle",
      "realization": "corpus-body",
      "canonical": {
        "category": "Decision-making",
        "home": "quality/rules_library.md",
        "body": "When the work has 3+ load-bearing structural decisions, surface them as a numbered set with a proposed default + alternatives + rationale per decision, and ask the operator to ratify the set in one pass — not piecemeal. 5-12 decisions is the right batch size."
      },
      "target_hooks": [
        {
          "target": "CLAUDE.md",
          "hook_type": "cross_ref",
          "text": "Governed by operating principle OP-19 — see quality/rules_library.md."
