      "data_risk_gate": "n/a",
      "emission_posture": "install-verbatim",
      "public_source_label": "inherited operating principle",
      "realization": "corpus-body",
      "canonical": {
        "category": "Decision-making",
        "home": "quality/rules_library.md",
        "body": "A \"lock\" on a decision means we're proceeding with this as the working baseline — not that we can never revisit. If new information surfaces, the lock can be re-opened. This reduces decision pressure and matches how real work goes."
      },
      "target_hooks": [
        {
          "target": "CLAUDE.md (decision posture)",
          "hook_type": "cross_ref",
          "text": "Governed by operating principle OP-20 — see quality/rules_library.md."
        }
