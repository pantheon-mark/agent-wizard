      "emission_posture": "install-verbatim",
      "public_source_label": "inherited operating principle",
      "realization": "corpus-body",
      "canonical": {
        "category": "Operator interaction",
        "home": "quality/rules_library.md",
        "body": "When the operator gives you a list of items, treat it as illustrative, not exhaustive. Proactively ask what's missing or pair the list with \"here's what I'd add — do these belong?\" Don't act as if the list is the complete set just because they offered one."
      },
      "target_hooks": [
        {
          "target": "CLAUDE.md (operator-interaction posture)",
          "hook_type": "cross_ref",
          "text": "Governed by operating principle OP-24 — see quality/rules_library.md."
        }
      ]
    },
