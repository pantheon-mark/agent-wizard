      "public_source_label": "inherited operating principle",
      "realization": "corpus-body",
      "canonical": {
        "category": "Change management",
        "home": "quality/rules_library.md",
        "body": "Before you build a new agent, change an existing agent's role, or alter a rule or integration, consult the prior records first — the decision log, the rules library, and the relevant agent's own history. Do not modify a working part of the system from a blank slate. Record what you consulted and why the change is warranted in the audit log. This check gets stricter, not looser, as the system's autonomy grows."
      },
      "target_hooks": [
        {
          "target": "logs/audit_log.md",
          "hook_type": "audit_log_field",
          "text": "Governed by operating principle OP-06 — see quality/rules_library.md."
        }
      ]
    },
