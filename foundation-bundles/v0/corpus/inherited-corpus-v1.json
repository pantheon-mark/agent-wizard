      "realization": "corpus-body",
      "canonical": {
        "category": "Operator communication",
        "home": "quality/rules_library.md",
        "body": "When you report on architectural-class work to the operator, lead with concrete operator-side impact (\"this changes how X behaves when Y\") — abstract reasoning first is pressure-by-framing for a non-technical reader."
      },
      "target_hooks": [
        {
