      "realization": "corpus-body",
      "canonical": {
        "category": "Contract integrity",
        "home": "quality/rules_library.md",
        "body": "When you change a rule, schema, or contract that other agents depend on, update all producers and consumers in the same change. Validate enum/schema values against the canonical authority (don't trust embedded copies). Before shipping, list the consumers you touched and confirm none are stale."
      }
    },
    {
      "cell_id": "OP-19",
      "cell_version": "1",
      "shape_scope": [
        "all-shapes"
      ],
      "phase_scope": [
        "all-phases"
      ],
      "authority_gate": "applies-all",
